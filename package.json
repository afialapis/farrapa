{
  "name": "farrapa",
  "version": "3.0.0-beta.10",
  "description": "diverse utils used by afialapis",
  "author": "Donato Lorenzo <donato@afialapis.com>",
  "contributors": [
    "Donato Lorenzo <donato@afialapis.com>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/afialapis/farrapa.git"
  },
  "bugs": {
    "url": "https://github.com/afialapis/farrapa/issues"
  },
  "homepage": "https://www.afialapis.com/os/farrapa",
  "files": [
    "package.json",
    "src",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./*": "./src/*/index.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "biome check ./src --reporter=github",
    "lint:fix": "biome check --write ./src --reporter=github",
    "reset": "rm -fr package-lock.json node_modules && npm i",
    "site": "npx arredemo build",
    "prepublishOnly": "npm run lint && npm run site"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5"
  },
  "dependencies": {
    "tinguir": "^0.0.7"
  }
}